# Example Home Assistant package for AlarmV1 wake-up briefing.
#
# ESPHome calls script.alarmv1_morning_briefing when the alarm is deliberately
# dismissed/stopped, not when it is snoozed or auto-times out.
#
# This example is tailored to the current HA setup discovered for AlarmV1:
# - Yandex Pogoda weather: weather.kievyan_pogoda
# - Presence gate: person.gurgen == home
# - Speaker/TTS: media_player.living_room_speaker_2 + tts.google_translate_en_com
# - Work destination: 40.184530,44.501020 (Yerevan, Dzorap Street 70/3)
#
# Commute lookup is intentionally on-demand inside the script. It uses the
# built-in Waze Travel Time integration action with realtime=true, so there is
# live traffic data and no paid Yandex Maps key.
#
# Prerequisite: add the Home Assistant "Waze Travel Time" integration once from
# Settings → Devices & services. Any placeholder origin/destination is fine;
# the script below calls waze_travel_time.get_travel_times directly.

script:
  alarmv1_morning_briefing:
    alias: AlarmV1 Morning Briefing
    mode: restart
    fields:
      media_player_entity_id:
        description: Speaker/media player for the spoken briefing
        example: media_player.living_room_speaker_2
    sequence:
      - action: weather.get_forecasts
        target:
          entity_id: weather.kievyan_pogoda
        data:
          type: hourly
        response_variable: alarmv1_weather

      - variables:
          commute_should_run: >-
            {{ now().isoweekday() <= 5
               and now().hour < 11
               and is_state('person.gurgen', 'home') }}

      - if:
          - condition: template
            value_template: "{{ commute_should_run }}"
        then:
          - action: waze_travel_time.get_travel_times
            data:
              origin: "{{ state_attr('zone.home', 'latitude') }}, {{ state_attr('zone.home', 'longitude') }}"
              destination: "40.184530, 44.501020"
              region: eu
              units: metric
              vehicle_type: car
              realtime: true
            response_variable: alarmv1_route
        else:
          - variables:
              alarmv1_route:
                waze_travel_time.get_travel_times:
                  routes: []

      - variables:
          forecast: >-
            {{ alarmv1_weather['weather.kievyan_pogoda'].forecast[0]
               if alarmv1_weather.get('weather.kievyan_pogoda') and
                  alarmv1_weather['weather.kievyan_pogoda'].forecast
               else {} }}
          condition: "{{ forecast.get('condition', states('weather.kievyan_pogoda')) }}"
          temperature: "{{ forecast.get('temperature', state_attr('weather.kievyan_pogoda', 'temperature')) }}"
          apparent_temperature: "{{ state_attr('weather.kievyan_pogoda', 'apparent_temperature') }}"
          precipitation: "{{ forecast.get('precipitation', '') }}"
          commute_routes: >-
            {{ alarmv1_route.get('waze_travel_time.get_travel_times', {}).get('routes', [])
               if alarmv1_route is defined else [] }}
          commute_minutes: >-
            {{ commute_routes[0].duration
               if commute_routes else 0 }}
          commute_text: >-
            {% if commute_should_run and commute_minutes | float(0) > 0 %}
              The Waze traffic estimate to work is about {{ commute_minutes | float | round(0) }} minutes.
            {% elif commute_should_run %}
              I could not get the current Waze traffic estimate to work.
            {% else %}
              Commute check skipped because it is not a weekday morning while you are home.
            {% endif %}
          weather_text: >-
            Today's Yandex weather: {{ condition }}{% if temperature not in ['unknown', 'unavailable', 'none', 'None', ''] %}, {{ temperature | round(0) }} degrees{% endif %}{% if apparent_temperature not in ['unknown', 'unavailable', 'none', 'None', ''] %}, feels like {{ apparent_temperature | round(0) }}{% endif %}{% if precipitation not in ['', none] %}, precipitation {{ precipitation }} millimeters{% endif %}.

      - action: tts.speak
        target:
          entity_id: tts.google_translate_en_com
        data:
          media_player_entity_id: "{{ media_player_entity_id | default('media_player.living_room_speaker_2') }}"
          message: "{{ weather_text }} {{ commute_text }}"
          cache: false
